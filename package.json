{
  "name": "aitg-monorepo",
  "private": true,
  "version": "0.1.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.9.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:generate": "pnpm --filter @aitg/database db:generate",
    "db:migrate": "pnpm --filter @aitg/database db:migrate",
    "db:migrate:deploy": "pnpm --filter @aitg/database db:migrate:deploy",
    "db:studio": "pnpm --filter @aitg/database db:studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "api:dev": "pnpm --filter @aitg/api dev",
    "api:workers": "pnpm --filter @aitg/api workers",
    "web:dev": "pnpm --filter @aitg/web dev",
    "db:seed": "pnpm --filter @aitg/database db:seed",
    "dev:all": "turbo run dev --parallel",
    "security:audit": "node scripts/security-audit.mjs"
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "typescript": "^5.6.3",
    "prettier": "^3.3.3"
  }
}