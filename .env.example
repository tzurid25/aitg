# ---- Shared ----
NODE_ENV=development

# ---- Database (packages/database) ----
# Local dev (matches docker-compose.yml)
DATABASE_URL="postgresql://aitg:aitg_dev_password@localhost:5432/aitg_dev?schema=public"

# ---- Redis (used starting Phase 5 - Cloud API / BullMQ) ----
REDIS_URL="redis://localhost:6379"

# ---- Auth (used starting Phase 5) ----
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
AUTH_SECRET=

# ---- Billing (used starting Phase 8) ----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ---- API (apps/api) ----
DASHBOARD_URL="http://localhost:3000"
WORKER_CONCURRENCY=5

# ---- Web dashboard (apps/web) ----
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# ---- GitHub App (Phase 7) ----
# NOTE: this is a GitHub *App*, a separate registration from the OAuth App
# used for sign-in above. One does not grant the other.
GITHUB_APP_ID=""
GITHUB_APP_PRIVATE_KEY=""
GITHUB_WEBHOOK_SECRET=""
NEXT_PUBLIC_GITHUB_APP_SLUG=""
# The App's OAuth credentials (same settings page as GITHUB_APP_ID).
# Required to verify that whoever completes installation actually controls it.
GITHUB_APP_CLIENT_ID=""
GITHUB_APP_CLIENT_SECRET=""
